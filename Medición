package com.proyecto.presionmonitorapp.modelo;

import javafx.beans.property.*;
import java.time.LocalDateTime;

public class Medicion {
    private final IntegerProperty id = new SimpleIntegerProperty();
    private final IntegerProperty pacienteId = new SimpleIntegerProperty();
    private final IntegerProperty presionSistolica = new SimpleIntegerProperty();
    private final IntegerProperty presionDiastolica = new SimpleIntegerProperty();
    private final IntegerProperty cantidadPulsos = new SimpleIntegerProperty();
    private final ObjectProperty<LocalDateTime> fechaHora = new SimpleObjectProperty<>();

    private final StringProperty categoriaPresion = new SimpleStringProperty();
    private final StringProperty nombrePaciente = new SimpleStringProperty();

    public Medicion() {
    }

    public Medicion(int id, int pacienteId, int sistolica, int diastolica,
                    int pulsos, LocalDateTime fechaHora) {
        setId(id);
        setPacienteId(pacienteId);
        setPresionSistolica(sistolica);
        setPresionDiastolica(diastolica);
        setCantidadPulsos(pulsos);
        setFechaHora(fechaHora);
        calcularCategoria();
    }

    public int getId() {
        return id.get();
    }

    public void setId(int id) {
        this.id.set(id);
    }

    public IntegerProperty idProperty() {
        return id;
    }

    public int getPacienteId() {
        return pacienteId.get();
    }

    public void setPacienteId(int id) {
        this.pacienteId.set(id);
    }

    public IntegerProperty pacienteIdProperty() {
        return pacienteId;
    }

    public int getPresionSistolica() {
        return presionSistolica.get();
    }

    public void setPresionSistolica(int valor) {
        this.presionSistolica.set(valor);
        calcularCategoria();
    }

    public IntegerProperty presionSistolicaProperty() {
        return presionSistolica;
    }

    public int getPresionDiastolica() {
        return presionDiastolica.get();
    }

    public void setPresionDiastolica(int valor) {
        this.presionDiastolica.set(valor);
        calcularCategoria();
    }

    public IntegerProperty presionDiastolicaProperty() {
        return presionDiastolica;
    }

    public int getCantidadPulsos() {
        return cantidadPulsos.get();
    }

    public void setCantidadPulsos(int pulsos) {
        this.cantidadPulsos.set(pulsos);
    }

    public IntegerProperty cantidadPulsosProperty() {
        return cantidadPulsos;
    }

    public LocalDateTime getFechaHora() {
        return fechaHora.get();
    }

    public void setFechaHora(LocalDateTime fecha) {
        this.fechaHora.set(fecha);
    }

    public ObjectProperty<LocalDateTime> fechaHoraProperty() {
        return fechaHora;
    }

    // presión arterial
    public String getCategoriaPresion() {
        calcularCategoria();
        return categoriaPresion.get();
    }

    public StringProperty categoriaPresionProperty() {
        calcularCategoria();
        return categoriaPresion;
    }

    public String getNombrePaciente() {
        return nombrePaciente.get();
    }

    public void setNombrePaciente(String nombre) {
        this.nombrePaciente.set(nombre);
    }

    public StringProperty nombrePacienteProperty() {
        return nombrePaciente;
    }

    // para calcular categoría
    private void calcularCategoria() {
        int sistolica = getPresionSistolica();
        int diastolica = getPresionDiastolica();
        String categoria = "Desconocida";

        if (sistolica < 120 && diastolica < 80) {
            categoria = "NORMAL";
        } else if (sistolica >= 120 && sistolica <= 129 && diastolica < 80) {
            categoria = "ELEVADA";
        } else if ((sistolica >= 130 && sistolica <= 139) || (diastolica >= 80 && diastolica <= 89)) {
            categoria = "HIPERTENSIÓN NIVEL 1";
        } else if (sistolica >= 140 || diastolica >= 90) {
            categoria = "HIPERTENSIÓN NIVEL 2";
        } else if (sistolica > 180 || diastolica > 120) {
            categoria = "CRISIS DE HIPERTENSIÓN";
        }

        this.categoriaPresion.set(categoria);
    }
}
