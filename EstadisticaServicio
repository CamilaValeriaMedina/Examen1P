package com.proyecto.presionmonitorapp.servicio;

import com.proyecto.presionmonitorapp.modelo.Paciente;

public class EstadisticaServicio {

    public double calcularIMC(double peso, double altura) {
        if (peso <= 0 || altura <= 0) return 0;
        // altura en cm → convertir a metros
        return peso / Math.pow(altura / 100, 2);
    }

    public String obtenerCategoriaIMC(double imc) {
        if (imc < 18.5) return "Bajo peso";
        if (imc < 25) return "Normal";
        if (imc < 30) return "Sobrepeso";
        return "Obesidad";
    }

    public String obtenerColorIMC(String categoria) {
        switch (categoria) {
            case "Bajo peso": return "#f39c12";
            case "Normal": return "#27ae60";
            case "Sobrepeso": return "#e67e22";
            default: return "#c0392b";
        }
    }

    public String formatearPromedios(double sistolica, double diastolica, double pulsos) {
        return String.format("SIS: %.1f | DIA: %.1f | PUL: %.1f",
                sistolica, diastolica, pulsos);
    }
}
