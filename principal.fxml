<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.image.ImageView?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.proyecto.presionmonitorapp.controlador.PrincipalController"
            styleClass="root-container">
    <VBox alignment="TOP_CENTER" spacing="10">

        <padding>
            <Insets bottom="15" left="15" right="15" top="15" />
        </padding>

        <Label styleClass="titulo-principal" text="Monitor de Presión Arterial">
            <font>
                <Font name="adelia" size="28.0" />
            </font>
            <graphic>
                <FontIcon iconLiteral="fas-heartbeat" iconSize="28" iconColor="red" />
            </graphic>
        </Label>

        <TitledPane animated="false" collapsible="false" text="📋 DATOS DEL PACIENTE">
            <VBox spacing="15">
                <padding>
                    <Insets bottom="15" left="15" right="15" top="10" />
                </padding>

                <GridPane hgap="15" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="100" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                        <ColumnConstraints halignment="RIGHT" minWidth="100" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                    </columnConstraints>

                    <Label text="Nombres:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField fx:id="txtNombres" promptText="Ingrese nombres"
                               GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <Label text="Apellidos:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                    <TextField fx:id="txtApellidos" promptText="Ingrese apellidos"
                               GridPane.columnIndex="3" GridPane.rowIndex="0" />

                    <Label text="Fecha Nacimiento:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <DatePicker fx:id="dpFechaNacimiento" promptText="dd/mm/aaaa"
                                GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    <Label text="Género:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                    <HBox alignment="CENTER_LEFT" spacing="15" GridPane.columnIndex="3" GridPane.rowIndex="1">
                        <RadioButton fx:id="rbMasculino" text="M" userData="M">
                            <toggleGroup>
                                <ToggleGroup fx:id="generoGroup" />
                            </toggleGroup>
                        </RadioButton>
                        <RadioButton fx:id="rbFemenino" text="F" toggleGroup="$generoGroup" userData="F" />
                        <RadioButton fx:id="rbOtro" text="Otro" toggleGroup="$generoGroup" userData="Otro" />
                    </HBox>

                    <Label text="Peso (kg):" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <TextField fx:id="txtPeso" promptText="Ej: 70.5" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    <Label text="Altura (cm):" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                    <TextField fx:id="txtAltura" promptText="Ej: 170" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                </GridPane>

                <HBox alignment="CENTER" spacing="15">
                    <Button fx:id="btnGuardarPaciente" onAction="#guardarPaciente"
                            styleClass="btn, btn-success" text="GUARDAR PACIENTE">
                        <graphic>
                            <FontIcon iconLiteral="fas-save" iconSize="16" />
                        </graphic>
                    </Button>
                    <Button fx:id="btnLimpiarPaciente" onAction="#limpiarFormularioPaciente"
                            styleClass="btn, btn-secondary" text="LIMPIAR">
                        <graphic>
                            <FontIcon iconLiteral="fas-eraser" iconSize="16" />
                        </graphic>
                    </Button>
                </HBox>
            </VBox>
        </TitledPane>

        <TitledPane animated="false" collapsible="false" text="👤 SELECCIONAR PACIENTE">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <padding>
                    <Insets bottom="10" left="15" right="15" top="10" />
                </padding>
                <Label text="Paciente:" styleClass="label-bold" />
                <ComboBox fx:id="cmbPacientes" prefWidth="400" promptText="Seleccione un paciente..."
                          styleClass="combo-pacientes" />
                <Button fx:id="btnCargarMediciones" onAction="#cargarMedicionesPaciente"
                        styleClass="btn, btn-primary" text="CARGAR MEDICIONES">
                    <graphic>
                        <FontIcon iconLiteral="fas-sync-alt" iconSize="16" />
                    </graphic>
                </Button>
            </HBox>
        </TitledPane>

        <TitledPane animated="false" collapsible="false" text="💓 NUEVA MEDICIÓN">
            <VBox spacing="15">
                <padding>
                    <Insets bottom="15" left="15" right="15" top="10" />
                </padding>

                <GridPane hgap="15" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="120" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="150" />
                        <ColumnConstraints halignment="RIGHT" minWidth="120" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="150" />
                    </columnConstraints>

                    <!-- Fila 0: Presiones -->
                    <Label text="Presión Sistólica:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <HBox alignment="CENTER_LEFT" spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <TextField fx:id="txtSistolica" prefWidth="100" promptText="120" />
                        <Label text="mmHg" styleClass="label-unidad" />
                    </HBox>

                    <Label text="Presión Diastólica:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                    <HBox alignment="CENTER_LEFT" spacing="5" GridPane.columnIndex="3" GridPane.rowIndex="0">
                        <TextField fx:id="txtDiastolica" prefWidth="100" promptText="80" />
                        <Label text="mmHg" styleClass="label-unidad" />
                    </HBox>

                    <Label text="Pulsos por minuto:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <HBox alignment="CENTER_LEFT" spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <TextField fx:id="txtPulsos" prefWidth="100" promptText="72" />
                        <Label text="bpm" styleClass="label-unidad" />
                    </HBox>

                    <Label text="Fecha y Hora:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <HBox spacing="10" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="2">
                        <Label fx:id="lblFechaHora" styleClass="fecha-automatica" />
                        <Label text=" " styleClass="label-ayuda" />
                    </HBox>
                </GridPane>

                <HBox alignment="CENTER" spacing="15">
                    <Button fx:id="btnAgregarMedicion" onAction="#agregarMedicion"
                            styleClass="btn, btn-primary" text="AGREGAR MEDICIÓN">
                        <graphic>
                            <FontIcon iconLiteral="fas-plus-circle" iconSize="16" />
                        </graphic>
                    </Button>
                    <Button fx:id="btnActualizarMedicion" onAction="#actualizarMedicion"
                            styleClass="btn, btn-warning" text="ACTUALIZAR" disable="true">
                        <graphic>
                            <FontIcon iconLiteral="fas-edit" iconSize="16" />
                        </graphic>
                    </Button>
                    <Button fx:id="btnCancelarMedicion" onAction="#cancelarEdicion"
                            styleClass="btn, btn-secondary" text="CANCELAR" disable="true">
                        <graphic>
                            <FontIcon iconLiteral="fas-times" iconSize="16" />
                        </graphic>
                    </Button>
                </HBox>

                <HBox alignment="CENTER" spacing="10" styleClass="categoria-preview">
                    <Label text="Categoría:" styleClass="label-bold" />
                    <Label fx:id="lblCategoriaPreview" text="---" styleClass="categoria-valor" />
                    <FontIcon iconLiteral="fas-arrow-right" iconSize="14" />
                    <Label fx:id="lblRecomendacionPreview" text="Ingrese valores para ver categoría"
                           styleClass="recomendacion-text" />
                </HBox>
            </VBox>
        </TitledPane>

        <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS">
            <!-- Panel izquierdo: Tabla de Pacientes -->
            <VBox spacing="5">
                <Label text="📋 LISTA DE PACIENTES" styleClass="tabla-titulo" />
                <TableView fx:id="tvPacientes" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colPacId" text="ID" prefWidth="50" />
                        <TableColumn fx:id="colPacNombres" text="Nombres" prefWidth="120" />
                        <TableColumn fx:id="colPacApellidos" text="Apellidos" prefWidth="120" />
                        <TableColumn fx:id="colPacFechaNac" text="Fecha Nac." prefWidth="90" />
                        <TableColumn fx:id="colPacGenero" text="Género" prefWidth="60" />
                        <TableColumn fx:id="colPacPeso" text="Peso" prefWidth="70" />
                        <TableColumn fx:id="colPacAltura" text="Altura" prefWidth="70" />
                        <TableColumn fx:id="colPacEdad" text="Edad" prefWidth="50" />
                    </columns>
                    <placeholder>
                        <Label text="No hay pacientes registrados" />
                    </placeholder>
                </TableView>
                <HBox spacing="5">
                    <Button fx:id="btnEliminarPaciente" onAction="#eliminarPaciente"
                            styleClass="btn, btn-danger" text="Eliminar">
                        <graphic>
                            <FontIcon iconLiteral="fas-user-minus" />
                        </graphic>
                    </Button>
                </HBox>
            </VBox>

            <VBox spacing="5">
                <Label text="📊 MEDICIONES DEL PACIENTE" styleClass="tabla-titulo" />
                <TableView fx:id="tvMediciones" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colMedFechaHora" text="Fecha/Hora" prefWidth="130" />
                        <TableColumn fx:id="colMedSistolica" text="SIS" prefWidth="60" />
                        <TableColumn fx:id="colMedDiastolica" text="DIA" prefWidth="60" />
                        <TableColumn fx:id="colMedPulsos" text="PUL" prefWidth="60" />
                        <TableColumn fx:id="colMedCategoria" text="Categoría" prefWidth="130" />
                    </columns>
                    <placeholder>
                        <Label text="Seleccione un paciente o no hay mediciones" />
                    </placeholder>
                </TableView>
                <HBox spacing="5">
                    <Button fx:id="btnEliminarMedicion" onAction="#eliminarMedicion"
                            styleClass="btn, btn-danger" text="Eliminar">
                        <graphic>
                            <FontIcon iconLiteral="fas-trash-alt" />
                        </graphic>
                    </Button>
                    <Button fx:id="btnEditarMedicion" onAction="#editarMedicion"
                            styleClass="btn, btn-warning" text="Editar">
                        <graphic>
                            <FontIcon iconLiteral="fas-edit" />
                        </graphic>
                    </Button>
                </HBox>
            </VBox>
        </SplitPane>

        <TitledPane animated="false" collapsible="false" text="📈 ESTADÍSTICAS DEL PACIENTE">
            <GridPane hgap="30" vgap="10">
                <padding>
                    <Insets bottom="10" left="15" right="15" top="10" />
                </padding>
                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT" minWidth="100" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                    <ColumnConstraints minWidth="100" />
                </columnConstraints>

                <Label text="Promedios:" styleClass="label-bold" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <Label fx:id="lblPromedios" text="SIS: 0.0 | DIA: 0.0 | PUL: 0.0"
                       styleClass="valor-promedio" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="IMC:" styleClass="label-bold" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <HBox alignment="CENTER_LEFT" spacing="15" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label fx:id="lblIMC" text="0.00" styleClass="valor-imc" />
                    <Label fx:id="lblCategoriaIMC" text="(Sin datos)" styleClass="categoria-imc" />
                </HBox>

                <StackPane GridPane.columnIndex="5" GridPane.rowIndex="3" GridPane.rowSpan="5">
                    <ImageView fx:id="imgIMC" fitHeight="120" fitWidth="120" />
                    <FontIcon fx:id="iconoIMC" iconLiteral="fas-smile" iconSize="40"
                              visible="false" managed="false" />
                </StackPane>
            </GridPane>
        </TitledPane>

        <TitledPane animated="false" collapsible="false" text="📅 PROMEDIOS GLOBALES POR RANGO DE FECHAS">
            <VBox spacing="10">
                <padding>
                    <Insets bottom="10" left="15" right="15" top="10" />
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label text="Desde:" styleClass="label-bold" />
                    <DatePicker fx:id="dpFechaInicio" promptText="dd/mm/aaaa" prefWidth="150" />
                    <Label text="Hasta:" styleClass="label-bold" />
                    <DatePicker fx:id="dpFechaFin" promptText="dd/mm/aaaa" prefWidth="150" />
                    <Button fx:id="btnCalcularPromediosGlobales" onAction="#calcularPromediosGlobales"
                            styleClass="btn, btn-info" text="CALCULAR">
                        <graphic>
                            <FontIcon iconLiteral="fas-calculator" iconSize="16" />
                        </graphic>
                    </Button>
                </HBox>

                <Label fx:id="lblPromediosGlobales" text="SIS: 0.0 | DIA: 0.0 | PUL: 0.0"
                       styleClass="resultado-global" />
            </VBox>
        </TitledPane>
    </VBox>
</ScrollPane>
